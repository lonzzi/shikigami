# ============================================================
# Shikigami 环境变量示例 — 复制为 .env 后填写
# 与 docker-compose.yml / schema.prisma 三处逐项对齐
# ============================================================

# ===== 运行时 =====
TZ=Asia/Shanghai
PORT=3000
DATABASE_URL=file:/data/shikigami.db
LOG_LEVEL=info

# ===== 鉴权 =====
# 生成: openssl rand -hex 32
JWT_SECRET=replace-with-32-bytes-random-hex
# 生成: openssl rand -hex 32  (独立于 JWT_SECRET, 用于 Settings 加密)
ENCRYPTION_KEY=replace-with-32-bytes-random-hex
ADMIN_USERNAME=admin
# 生成: bun -e 'import bcryptjs from "bcryptjs"; console.log(await bcryptjs.hash("your-password", 10))'
ADMIN_PASSWORD=$2a$10$REPLACE_WITH_BCRYPT_HASH

# ===== AI（OpenAI 兼容；可指 Ollama http://host:11434/v1）=====
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-replace-me
LLM_MODEL=gpt-4o-mini
LLM_REVIEW_THRESHOLD=0.7
LLM_DAILY_BUDGET_USD=1.0

# ===== qBittorrent =====
QBT_BASE_URL=http://qbittorrent:8080
QBT_USERNAME=admin
QBT_PASSWORD=adminadmin
QBT_API_KEY=
QBT_CATEGORY_DEFAULT=动漫
QBT_SAVEPATH_ROOT=/downloads
QBT_STALLED_TIMEOUT_HOURS=24

# ===== Jellyfin / Emby（MEDIA_SERVER_TYPE 决定哪组生效）=====
MEDIA_SERVER_TYPE=jellyfin
JELLYFIN_BASE_URL=http://jellyfin:8096
JELLYFIN_API_KEY=
EMBY_BASE_URL=http://emby:8096
EMBY_API_KEY=

# ===== Bangumi =====
BANGUMI_ACCESS_TOKEN=
BANGUMI_USER_AGENT=lonzzi/shikigami (https://github.com/lonzzi/shikigami)

# ===== TMDB =====
TMDB_API_KEY=
TMDB_LANGUAGE=zh-CN

# ===== 媒体库路径（LIBRARY_ROOT 必须与 DOWNLOADS_ROOT 同一文件系统, 否则硬链接降级为复制）=====
LIBRARY_ROOT=/media/library
DOWNLOADS_ROOT=/downloads

# ===== 调度（cron 表达式启动校验, 错格式 fail-fast）=====
RSS_SYNC_INTERVAL=*/15 * * * *
QB_POLL_INTERVAL_SECONDS=30

# ===== 通知 =====
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
WECHAT_WORK_WEBHOOK_KEY=

# ===== HTTP 代理 =====
HTTPS_PROXY=

# ===== Docker 端口映射变量（compose 用）=====
QBT_WEBUI_PORT=8080
QBT_BT_PORT=6881
